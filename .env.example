# Supabase connection (get from https://app.supabase.com → Project Settings → API)
# Leave empty to run in local-only demo mode (localStorage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Regente server (F10.7) — quando setado, todo o runtime (definitions,
# scheduler, instances) roteia pelo regente-server Go em vez do localStorage.
# Inicie o server com:
#   cd projects/Regente/server && go run . -api-token dev-token
# E o agent:
#   cd projects/Regente/agent  && go run . -token dev-token -caps COMMAND,REST
VITE_REGENTE_SERVER_URL=
VITE_REGENTE_TOKEN=dev-token
